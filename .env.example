# =====================================================
# BACKEND ENV VARS (Spring Boot / Render Dashboard)
# =====================================================
# Set all production values in Render dashboard → Environment
# NEVER commit actual values — this file is safe to commit.
# =====================================================

# PostgreSQL — get from Supabase → Project Settings → Database → Connection string
DB_URL=jdbc:postgresql://your-host.supabase.co:5432/postgres
DB_USER=postgres
DB_PASS=ROTATE_THIS_CHANGE_YOUR_SUPABASE_DB_PASSWORD

# REQUIRED: Must be at least 64 characters long.
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_THIS_WITH_OUTPUT_OF_openssl_rand_-base64_64

# Gmail App Password (generate at myaccount.google.com/apppasswords)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=ROTATE_THIS_GENERATE_NEW_GMAIL_APP_PASSWORD

# Supabase (get from Supabase → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# ⚠️  IMPORTANT: This MUST be the SERVICE ROLE KEY — NOT the anon key.
# The service role key bypasses RLS entirely, which is correct for backend use.
# Get it from: Supabase → Project Settings → API → "service_role" key
# ROTATE THIS KEY if it was ever exposed (e.g. committed to git).
SUPABASE_KEY=ROTATE_THIS_REGENERATE_SERVICE_ROLE_KEY

# ❌ NEVER use the anon/public key here. The anon key is for frontend only.
# SUPABASE_ANON_KEY should only be in frontend/.env (VITE_SUPABASE_ANON_KEY)

# REQUIRED in production: Set to your actual frontend domain.
# NEVER use * as the value — that disables CORS protection.
APP_FRONTEND_URL=https://your-frontend-domain.com

# Email branding — what recipients see as the sender
# Display name shown in email client (e.g. "FriendsHub")
APP_MAIL_DISPLAY_NAME=FriendsHub
# From address shown to recipients — Gmail SMTP sends on behalf of this
# If Gmail blocks spoofed domains, change to: anand.jay426344@gmail.com
APP_MAIL_FROM=noreply@friendshub.me
# Reply-To address (where recipients reply)
APP_MAIL_REPLY_TO=support@friendshub.me

# Email link base URLs (no trailing slash)
# Verification link: APP_VERIFICATION_URL?token=<token>
APP_VERIFICATION_URL=https://friendshub.me/verify
# Password reset link: APP_RESET_PASSWORD_URL?token=<token>
APP_RESET_PASSWORD_URL=https://friendshub.me/reset-password

# NOTE: Do NOT set PORT — Render injects it automatically

# Redis (get free instance from https://upstash.com)
REDIS_URL=redis://default:your_password@your-endpoint.upstash.io:6379

# Kafka (get free instance from https://upstash.com/kafka)
KAFKA_SERVERS=your-endpoint.upstash.io:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="your_user" password="your_password";

